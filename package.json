{
  "name": "rtsp-streamer",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && npm run build:html",
    "build:html": "tsc -p tsconfig.html.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "examples:http": "tsx examples/http/server.ts",
    "examples:express": "tsx examples/express/server.ts",
    "examples:fastify": "tsx examples/fastify/server.ts",
    "examples:nest": "tsx --tsconfig examples/nest/tsconfig.json examples/nest/server.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.html.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biswasray/rtsp-streamer.git"
  },
  "keywords": [],
  "author": "Subhasish Biswasray",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/biswasray/rtsp-streamer/issues"
  },
  "homepage": "https://github.com/biswasray/rtsp-streamer#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fastify/static": "^9.3.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "fastify": "^5.10.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
